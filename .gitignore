# Maven build output
target/
**/target/

# Compiled Java bytecode (safety net outside target/)
*.class

# Maven compiler status files (contain local developer paths)
*.lst

# Node / npm installs
node_modules/
**/node_modules/

# Frontend build output
dist/
build/
coverage/
**/dist/
**/build/
**/coverage/

# Expo / React Native generated files
.expo/
.expo-shared/
**/.expo/
**/.expo-shared/
*.expo

# Android generated files
.gradle/
**/.gradle/
local.properties
captures/
*.keystore
*.jks
**/android/app/build/
**/android/build/

# Logs and temp files
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / editor files
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
